# Copy to .env and fill in values. Restart the app after changing.
# API (backend)
EXPO_PUBLIC_API_URL=

# Exit gate (full URL to exit-gate/index.html — QR on receipt will open this with ?token=)
# Example: https://your-bucket.s3.amazonaws.com/exit-gate/index.html
EXPO_PUBLIC_EXIT_GATE_URL=

# Cognito (required for login/signup; omit to use "Continue as guest")
EXPO_PUBLIC_USER_POOL_ID=
EXPO_PUBLIC_USER_POOL_CLIENT_ID=
EXPO_PUBLIC_AWS_REGION=us-east-1

# Razorpay (for payments)
EXPO_PUBLIC_RZP_KEY_ID=
